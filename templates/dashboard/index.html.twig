<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <link
            href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css"
            rel="stylesheet"
            integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB"
            crossorigin="anonymous"
    />
    <title>About us</title>
</head>
<body style="background-color: #dadada">
<header>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">French budget</a>
            <button
                    class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div
                    class="collapse navbar-collapse justify-content-end"
                    id="navbarNav"
            >
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/about-us">About us & contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Go to dashboard</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<h2 class="m-3">
    Welcome {{ user }}
</h2>
<main>
    <div class="container mt-3">
        <div class="row gap-2" style="height: 67vh;">
            <div class="col-7">
                <div class="row gap-2">
                    <div class="col bg-light rounded" style="height: 16rem">
                        awdaw
                    </div>
                    <div class="col bg-light rounded">
                        awd
                    </div>
                </div>
                <div class="row mt-5" style="height: 21rem">
                    <div class="col bg-light rounded">
                        hi
                    </div>
                </div>
            </div>
            <div class="col-4 bg-secondary rounded">
                {{ form(form) }}
            </div>
        </div>
    </div>
</main>
<script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"
></script>
</body>
</html>