{% extends 'base.html.twig' %}
{% block title %}Dashboard{% endblock %}

{% block body %}
<header>
    <nav class="navbar navbar-expand-lg bg-body-tertiary">
        <div class="container-fluid">
            <a class="navbar-brand" href="/">French budget</a>
            <button
                    class="navbar-toggler"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#navbarNav"
                    aria-controls="navbarNav"
                    aria-expanded="false"
                    aria-label="Toggle navigation"
            >
                <span class="navbar-toggler-icon"></span>
            </button>
            <div
                    class="collapse navbar-collapse justify-content-end"
                    id="navbarNav"
            >
                <ul class="navbar-nav">
                    <li class="nav-item">
                        <a class="nav-link" href="/about-us">About us & contact</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/dashboard">Go to dashboard</a>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>
<h2 class="m-3">
    Welcome user{{ user }}
</h2>
<main>
    <div class="container mt-3">
        <div class="row gap-4" style="height: 67vh;">
            <div class="col-7">
                <div class="row gap-4">
                    <div class="col bg-light rounded" style="height: 16rem">
                        <h3 class="d-flex justify-content-center">
                            Recente inkomen
                        </h3>
                    </div>
                    <div class="col bg-light rounded">
                        <h3 class="d-flex justify-content-center">
                            Recente transacties
                        </h3>
                    </div>
                </div>
                <div class="row mt-5" style="height: 21rem">
                    <div class="col bg-light rounded">
                        <h4 class="d-flex justify-content-center">
                            {{ render_chart(chart) }}
                        </h4>
                    </div>
                </div>
            </div>
            <div class="col-4 bg-secondary rounded">
                {{ form(form) }}
            </div>
        </div>
    </div>
</main>
<script
        src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"
        integrity="sha384-FKyoEForCGlyvwx9Hj09JcYn3nv7wiPVlz7YYwJrWVcXK/BmnVDxM+D2scQbITxI"
        crossorigin="anonymous"
></script>
{% endblock %}